<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Session 1 - Transpositions | Premium English</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <style>
        :root {
            --azul-noche: #0B192C; /* Color principal corporativo */
            --dorado-exito: #D4AF37; /* Color de acento para lujo y prestigio */
            --negro-ebano: #121212; /* Texto principal */
            --blanco: #FFFFFF;
            --gris-claro: #F8F9FA;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--gris-claro);
            color: var(--negro-ebano);
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }

        header {
            background-color: var(--azul-noche);
            width: 100%;
            padding: 2rem 0;
            text-align: center;
            border-bottom: 4px solid var(--dorado-exito);
            margin-bottom: 3rem;
        }

        h1 {
            font-family: 'Playfair Display', serif;
            color: var(--blanco);
            margin: 0;
            font-size: 2.5rem;
            letter-spacing: 1px;
        }

        .container {
            max-width: 800px;
            width: 90%;
            background: var(--blanco);
            padding: 2.5rem;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }

        .instruction {
            color: var(--azul-noche);
            font-weight: 700;
            margin-bottom: 2rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-left: 4px solid var(--dorado-exito);
            padding-left: 1rem;
        }

        .row {
            display: flex;
            align-items: center;
            padding: 1rem 0;
            border-bottom: 1px solid #eee;
            gap: 20px;
        }

        .btn-trigger {
            background-color: var(--azul-noche);
            color: var(--blanco);
            border: none;
            padding: 0.8rem 1.2rem;
            border-radius: 4px;
            cursor: pointer;
            font-family: 'Montserrat', sans-serif;
            font-weight: 600;
            min-width: 160px;
            transition: all 0.3s ease;
        }

        .btn-trigger:hover {
            background-color: var(--dorado-exito);
        }

        .btn-trigger:disabled {
            background-color: #ddd;
            color: #888;
            cursor: not-allowed;
        }

        .response {
            font-size: 1.1rem;
            color: var(--negro-ebano);
            opacity: 0;
            transform: translateX(10px);
            transition: all 0.5s ease;
        }

        .response.visible {
            opacity: 1;
            transform: translateX(0);
        }

        strong {
            color: var(--dorado-exito);
        }
    </style>
</head>
<body>

<header>
    <h1>PREMIUM ENGLISH</h1>
</header>

<div class="container">
    <div class="instruction">Session 1: The Wrong Suitcase - Transpositions</div>
    
    <div class="row" style="background: #fdfdfd;">
        <div style="min-width: 160px; font-weight: bold; color: var(--dorado-exito);">BASE SENTENCE:</div>
        <div class="response visible">Is this your suitcase?</div>
    </div>

    <div id="activity-root"></div>
</div>

<script>
    const steps = [
        { label: "(ella) She", text: "Is this <strong>her</strong> suitcase?" },
        { label: "(afirmativo) Affirmative", text: "<strong>This is</strong> her suitcase." },
        { label: "(él) He", text: "This is <strong>his</strong> suitcase." },
        { label: "(azul) Blue", text: "His suitcase <strong>is blue</strong>." },
        { label: "(yo) I", text: "<strong>My</strong> suitcase is blue." },
        { label: "(negativo) Negative", text: "My suitcase is <strong>not</strong> blue." },
        { label: "(nosotros) We", text: "<strong>Our</strong> suitcase is not blue." },
        { label: "(rojo) Red", text: "Our suitcase is not <strong>red</strong>." },
        { label: "(ellos) They", text: "<strong>Their</strong> suitcase is not red." },
        { label: "(bolsos) Bags", text: "Their <strong>bags are</strong> not red." },
        { label: "(allá) Over there", text: "Their bags are <strong>over there</strong>." },
        { label: "(interrogativo) Interrogative", text: "<strong>Are</strong> their bags over there?" }
    ];

    const root = document.getElementById('activity-root');

    steps.forEach((step, index) => {
        const row = document.createElement('div');
        row.className = 'row';

        const btn = document.createElement('button');
        btn.className = 'btn-trigger';
        btn.innerHTML = step.label;
        btn.onclick = () => {
            const resp = document.getElementById(`resp-${index}`);
            resp.classList.add('visible');
            btn.disabled = true;
            btn.style.backgroundColor = '#f1f1f1';
            btn.style.color = '#0B192C';
        };

        const responseDiv = document.createElement('div');
        responseDiv.id = `resp-${index}`;
        responseDiv.className = 'response';
        responseDiv.innerHTML = step.text;

        row.appendChild(btn);
        row.appendChild(responseDiv);
        root.appendChild(row);
    });
</script>

</body>
</html>
